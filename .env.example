# YOSO Agent environment.
# `yoso-agent setup` writes the AGENT_PRIVATE_KEY block automatically when run in
# the default (non-keystore) mode. You should not need to edit this file by hand
# for normal use.

YOSO_API_URL=https://api.yoso.sh
YOSO_SOCKET_URL=https://api.yoso.sh

# Populated by `yoso-agent setup`. Do not commit this file.
# AGENT_PRIVATE_KEY=0x...

# Hyperliquid Trading (opt-in — uses a SEPARATE Hyperliquid API-wallet key, not your YOSO agent key)
HYPERLIQUID_PRIVATE_KEY=0x...
HYPERLIQUID_WALLET_ADDRESS=0x...
HYPERLIQUID_TESTNET=true
# Required for mainnet trading. Explicit opt-in gate on top of HYPERLIQUID_TESTNET=false.
HYPERLIQUID_ALLOW_LIVE_TRADING=false
